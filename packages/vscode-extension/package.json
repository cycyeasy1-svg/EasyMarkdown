{
  "name": "easymarkdown",
  "displayName": "EasyMarkdown",
  "description": "Source-backed live preview + inline editing for Markdown (tables, column filters, heading fold, outline) with a zero-diff result. A VSCode edition of EasyMarkdown's keep mode.",
  "version": "1.3.2",
  "publisher": "easy-chen",
  "author": {
    "name": "Easy Chen"
  },
  "license": "MIT",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "markdown",
    "preview",
    "wysiwyg",
    "table",
    "editor"
  ],
  "main": "./dist/extension.cjs",
  "activationEvents": [
    "onLanguage:markdown",
    "onCustomEditor:easymarkdown.keep",
    "onCommand:easymarkdown.openWithKeep",
    "onCommand:easymarkdown.openWithText",
    "onCommand:easymarkdown.openKeepToSide"
  ],
  "contributes": {
    "customEditors": [
      {
        "viewType": "easymarkdown.keep",
        "displayName": "EasyMarkdown Keep",
        "selector": [
          { "filenamePattern": "*.md" },
          { "filenamePattern": "*.markdown" }
        ],
        "priority": "option"
      }
    ],
    "configuration": {
      "title": "EasyMarkdown Keep",
      "properties": {
        "easymarkdown.keep.language": {
          "type": "string",
          "enum": ["auto", "en", "zh", "ja"],
          "default": "auto",
          "description": "UI language for the keep editor (auto follows VSCode's display language)."
        },
        "easymarkdown.keep.rememberMode": {
          "type": "boolean",
          "default": true,
          "description": "Open Markdown files in the mode (keep or source) you last chose explicitly. Turn off to always open in keep mode (the default editor)."
        },
        "easymarkdown.keep.scrollSync": {
          "type": "boolean",
          "default": true,
          "description": "Keep the keep view and a side-by-side source editor of the same file scroll-locked (both directions)."
        }
      }
    },
    "commands": [
      {
        "command": "easymarkdown.openWithKeep",
        "title": "Open in Keep Mode",
        "category": "EasyMarkdown",
        "icon": "$(book)"
      },
      {
        "command": "easymarkdown.openWithText",
        "title": "Open in Source Mode",
        "category": "EasyMarkdown",
        "icon": "$(code)"
      },
      {
        "command": "easymarkdown.openKeepToSide",
        "title": "Open Keep View to the Side",
        "category": "EasyMarkdown",
        "icon": "$(split-horizontal)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "easymarkdown.openWithKeep",
          "when": "resourceExtname =~ /\\.(md|markdown)$/ && activeCustomEditorId != easymarkdown.keep && !inDiffEditor",
          "group": "navigation@9"
        },
        {
          "command": "easymarkdown.openKeepToSide",
          "when": "editorLangId == markdown && activeCustomEditorId != easymarkdown.keep && !inDiffEditor",
          "group": "navigation@10"
        },
        {
          "command": "easymarkdown.openWithText",
          "when": "activeCustomEditorId == easymarkdown.keep",
          "group": "navigation@9"
        }
      ],
      "editor/context": [
        {
          "command": "easymarkdown.openWithKeep",
          "when": "editorLangId == markdown && !inDiffEditor",
          "group": "navigation@9"
        },
        {
          "command": "easymarkdown.openKeepToSide",
          "when": "editorLangId == markdown && !inDiffEditor",
          "group": "navigation@10"
        }
      ],
      "editor/title/context": [
        {
          "command": "easymarkdown.openWithKeep",
          "when": "resourceExtname =~ /\\.(md|markdown)$/ && !inDiffEditor",
          "group": "navigation@9"
        },
        {
          "command": "easymarkdown.openKeepToSide",
          "when": "resourceExtname =~ /\\.(md|markdown)$/ && !inDiffEditor",
          "group": "navigation@10"
        }
      ],
      "commandPalette": [
        {
          "command": "easymarkdown.openWithKeep",
          "when": "resourceExtname =~ /\\.(md|markdown)$/ && !inDiffEditor"
        },
        {
          "command": "easymarkdown.openWithText",
          "when": "resourceExtname =~ /\\.(md|markdown)$/ && !inDiffEditor"
        },
        {
          "command": "easymarkdown.openKeepToSide",
          "when": "resourceExtname =~ /\\.(md|markdown)$/ && !inDiffEditor"
        }
      ]
    },
    "keybindings": [
      {
        "command": "easymarkdown.openWithKeep",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m",
        "when": "resourceExtname =~ /\\.(md|markdown)$/ && activeCustomEditorId != easymarkdown.keep && !inDiffEditor"
      },
      {
        "command": "easymarkdown.openWithText",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m",
        "when": "activeCustomEditorId == easymarkdown.keep && !inDiffEditor"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "vscode:prepublish": "node esbuild.mjs --production"
  },
  "devDependencies": {
    "@types/vscode": "^1.84.0",
    "esbuild": "^0.24.0"
  },
  "dependencies": {
    "katex": "^0.16.11",
    "mermaid": "^11.15.0"
  }
}
