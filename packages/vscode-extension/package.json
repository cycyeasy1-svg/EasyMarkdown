{
  "name": "easymarkdown-keep",
  "displayName": "EasyMarkdown Keep",
  "description": "Source-backed live preview + inline editing for Markdown (tables, filters, zero-diff). A VSCode port of EasyMarkdown's keep mode.",
  "version": "0.0.1",
  "publisher": "easymarkdown",
  "license": "MIT",
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.cjs",
  "contributes": {
    "customEditors": [
      {
        "viewType": "easymarkdown.keep",
        "displayName": "EasyMarkdown Keep",
        "selector": [
          { "filenamePattern": "*.md" },
          { "filenamePattern": "*.markdown" }
        ],
        "priority": "option"
      }
    ],
    "configuration": {
      "title": "EasyMarkdown Keep",
      "properties": {
        "easymarkdown.keep.language": {
          "type": "string",
          "enum": ["auto", "en", "zh", "ja"],
          "default": "auto",
          "description": "UI language for the keep editor (auto follows VSCode's display language)."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "vscode:prepublish": "node esbuild.mjs --production"
  },
  "devDependencies": {
    "@types/vscode": "^1.84.0",
    "esbuild": "^0.24.0"
  },
  "dependencies": {
    "katex": "^0.16.11",
    "mermaid": "^11.15.0"
  }
}
