{
  "name": "easymarkdown-keep",
  "displayName": "EasyMarkdown Keep",
  "description": "Source-backed live preview + inline editing for Markdown (tables, filters, zero-diff). A VSCode port of EasyMarkdown's keep mode.",
  "version": "0.0.1",
  "publisher": "easymarkdown",
  "license": "MIT",
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.cjs",
  "contributes": {
    "customEditors": [
      {
        "viewType": "easymarkdown.keep",
        "displayName": "EasyMarkdown Keep",
        "selector": [
          { "filenamePattern": "*.md" },
          { "filenamePattern": "*.markdown" }
        ],
        "priority": "option"
      }
    ],
    "configuration": {
      "title": "EasyMarkdown Keep",
      "properties": {
        "easymarkdown.keep.language": {
          "type": "string",
          "enum": ["auto", "en", "zh", "ja"],
          "default": "auto",
          "description": "UI language for the keep editor (auto follows VSCode's display language)."
        }
      }
    },
    "commands": [
      {
        "command": "easymarkdown.openWithKeep",
        "title": "Open in Keep Mode",
        "category": "EasyMarkdown",
        "icon": "$(book)"
      },
      {
        "command": "easymarkdown.openWithText",
        "title": "Open in Source Mode",
        "category": "EasyMarkdown",
        "icon": "$(code)"
      },
      {
        "command": "easymarkdown.openKeepToSide",
        "title": "Open Keep View to the Side",
        "category": "EasyMarkdown",
        "icon": "$(split-horizontal)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "easymarkdown.openWithKeep",
          "when": "resourceExtname =~ /\\.(md|markdown)$/ && activeCustomEditorId != easymarkdown.keep",
          "group": "navigation@9"
        },
        {
          "command": "easymarkdown.openKeepToSide",
          "when": "editorLangId == markdown && activeCustomEditorId != easymarkdown.keep",
          "group": "navigation@10"
        },
        {
          "command": "easymarkdown.openWithText",
          "when": "activeCustomEditorId == easymarkdown.keep",
          "group": "navigation@9"
        }
      ],
      "editor/context": [
        {
          "command": "easymarkdown.openWithKeep",
          "when": "editorLangId == markdown",
          "group": "navigation@9"
        },
        {
          "command": "easymarkdown.openKeepToSide",
          "when": "editorLangId == markdown",
          "group": "navigation@10"
        }
      ],
      "editor/title/context": [
        {
          "command": "easymarkdown.openWithKeep",
          "when": "resourceExtname =~ /\\.(md|markdown)$/",
          "group": "navigation@9"
        },
        {
          "command": "easymarkdown.openKeepToSide",
          "when": "resourceExtname =~ /\\.(md|markdown)$/",
          "group": "navigation@10"
        }
      ],
      "commandPalette": [
        {
          "command": "easymarkdown.openWithKeep",
          "when": "resourceExtname =~ /\\.(md|markdown)$/"
        },
        {
          "command": "easymarkdown.openWithText",
          "when": "resourceExtname =~ /\\.(md|markdown)$/"
        },
        {
          "command": "easymarkdown.openKeepToSide",
          "when": "resourceExtname =~ /\\.(md|markdown)$/"
        }
      ]
    },
    "keybindings": [
      {
        "command": "easymarkdown.openWithKeep",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m",
        "when": "resourceExtname =~ /\\.(md|markdown)$/ && activeCustomEditorId != easymarkdown.keep"
      },
      {
        "command": "easymarkdown.openWithText",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m",
        "when": "activeCustomEditorId == easymarkdown.keep"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "vscode:prepublish": "node esbuild.mjs --production"
  },
  "devDependencies": {
    "@types/vscode": "^1.84.0",
    "esbuild": "^0.24.0"
  },
  "dependencies": {
    "katex": "^0.16.11",
    "mermaid": "^11.15.0"
  }
}
