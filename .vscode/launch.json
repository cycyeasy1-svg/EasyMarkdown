{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Keep Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/vscode-extension"
      ],
      "outFiles": ["${workspaceFolder}/packages/vscode-extension/dist/**/*.js"],
      "preLaunchTask": "build keep extension"
    }
  ]
}
