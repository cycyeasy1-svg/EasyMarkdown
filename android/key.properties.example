# Copy this file to android/key.properties (gitignored) and fill in your values.
# Generate the keystore once (see docs/mobile.md):
#   keytool -genkeypair -v -keystore android/app/easymarkdown.keystore \
#     -alias easymarkdown -keyalg RSA -keysize 2048 -validity 10000 \
#     -dname "CN=EasyMarkdown, O=EasyMarkdown, C=CN"
#
# storeFile is resolved relative to android/app/.
storeFile=easymarkdown.keystore
storePassword=YOUR_KEYSTORE_PASSWORD
keyAlias=easymarkdown
keyPassword=YOUR_KEY_PASSWORD
